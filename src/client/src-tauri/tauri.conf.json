{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copilot Chef",
  "version": "0.1.0",
  "identifier": "com.copilot-chef.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Copilot Chef",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/copilot-chef/copilot-chef/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDMjk5OUE4MDE3N0I1ODQKUldTRXRYY0JxSmtwN0UvYUkwQlZIdElmOUtXd2ttREQzZ0JGNTR2dVVuaXUvMTFoTTNRQUNpWjYK"
    },
    "shell": {
      "open": false,
      "sidecar": false,
      "scope": [
        {
          "name": "copilot-chef-server",
          "cmd": "copilot-chef-server",
          "args": true
        }
      ]
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/*"]
      }
    }
  }
}
