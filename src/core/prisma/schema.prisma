generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
  SNACK
}

model MealPlan {
  id           String        @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  isCurrent    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  meals        Meal[]
  groceryLists GroceryList[]
}

model Meal {
  id              String    @id @default(cuid())
  mealPlanId      String?
  name            String
  date            DateTime  @default(now())
  mealType        MealType
  notes           String?
  ingredientsJson String    @default("[]")
  createdAt       DateTime  @default(now())
  mealPlan        MealPlan? @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)
  logs            MealLog[]

  @@index([mealPlanId, date])
}

model GroceryList {
  id         String        @id @default(cuid())
  mealPlanId String?
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  mealPlan   MealPlan?     @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)
  items      GroceryItem[]
}

model GroceryItem {
  id            String      @id @default(cuid())
  groceryListId String
  name          String
  quantity      Float?
  unit          String?
  category      String?
  checked       Boolean     @default(false)
  sortOrder     Int         @default(0)
  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)

  @@index([groceryListId, sortOrder])
}

model UserPreference {
  id                  String   @id @default("default")
  dietaryRestrictions String?
  householdSize       Int      @default(2)
  cuisinePreferences  String?
  avoidIngredients    String?
  notes               String?
  updatedAt           DateTime @updatedAt
}

model MealLog {
  id        String   @id @default(cuid())
  date      DateTime
  mealType  MealType
  mealName  String
  cooked    Boolean  @default(true)
  mealId    String?
  meal      Meal?    @relation(fields: [mealId], references: [id], onDelete: SetNull)

  @@index([date])
}
