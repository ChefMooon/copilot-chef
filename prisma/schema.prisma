generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("COPILOT_CHEF_DATABASE_URL")
}

model Meal {
  id                   String              @id @default(cuid())
  name                 String
  date                 DateTime?           @default(now())
  mealType             String
  mealTypeDefinitionId String?
  mealTypeDefinition   MealTypeDefinition? @relation(fields: [mealTypeDefinitionId], references: [id], onDelete: SetNull)
  notes                String?
  ingredientsJson      String              @default("[]")
  description          String?
  instructionsJson     String              @default("[]")
  servings             Int                 @default(2)
  prepTime             Int?
  cookTime             Int?
  cuisine              String?
  servingsOverride     Int?
  recipeId             String?
  recipe               Recipe?             @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  createdAt            DateTime            @default(now())

  @@index([date])
  @@index([mealTypeDefinitionId])
  @@index([cuisine])
  @@index([recipeId])
}

model MealTypeProfile {
  id          String               @id @default(cuid())
  name        String
  color       String               @default("#3B5E45")
  description String?
  isDefault   Boolean              @default(false)
  priority    Int                  @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  mealTypes   MealTypeDefinition[]

  @@index([isDefault, priority])
  @@index([startDate, endDate, priority])
}

model MealTypeDefinition {
  id         String          @id @default(cuid())
  profileId  String
  name       String
  slug       String
  color      String
  enabled    Boolean         @default(true)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  profile    MealTypeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  meals      Meal[]

  @@unique([profileId, slug])
  @@unique([profileId, sortOrder])
  @@index([profileId, sortOrder])
}

model GroceryList {
  id         String        @id @default(cuid())
  name       String
  date       DateTime      @default(now())
  favourite  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  items      GroceryItem[]

  @@index([date])
}

model GroceryItem {
  id            String      @id @default(cuid())
  groceryListId String
  name          String
  qty           String?
  unit          String?
  category      String      @default("Other")
  notes         String?
  meal          String?
  checked       Boolean     @default(false)
  sortOrder     Int         @default(0)
  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)

  @@index([groceryListId, sortOrder])
}

model UserPreference {
  id                     String   @id @default("default")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  householdSize          Int      @default(2)
  cookingLength          String   @default("weeknight")
  dietaryTags            String   @default("")
  favoriteCuisines       String   @default("")
  avoidCuisines          String   @default("")
  avoidIngredients       String   @default("[]")
  pantryStaples          String   @default("[]")
  planningNotes          String   @default("")
  nutritionTags          String   @default("")
  skillLevel             String   @default("home-cook")
  budgetRange            String   @default("moderate")
  chefPersona            String   @default("coach")
  replyLength            String   @default("balanced")
  emojiUsage             String   @default("occasional")
  autoImproveChef        Boolean  @default(true)
  contextAwareness       Boolean  @default(true)
  seasonalAwareness      Boolean  @default(true)
  seasonalRegion         String   @default("eastern-us")
  proactiveTips          Boolean  @default(false)
  autoGenerateGrocery    Boolean  @default(true)
  consolidateIngredients Boolean  @default(true)
  defaultPlanLength      String   @default("7")
  groceryGrouping        String   @default("category")
  defaultRecipeView      String   @default("basic")
  defaultUnitMode        String   @default("cup")
  saveChatHistory        Boolean  @default(true)
  reasoningEffort        String   @default("")
}

model Recipe {
  id           String             @id @default(cuid())
  title        String
  normalizedTitle String?         @unique
  description  String?
  servings     Int                @default(2)
  prepTime     Int?
  cookTime     Int?
  difficulty   String?
  cuisine      String?
  instructions String
  sourceUrl    String?
  normalizedSourceUrl String?     @unique
  sourceLabel  String?
  origin       String             @default("manual")
  favourite    Boolean            @default(false)
  rating       Int?
  cookNotes    String?
  lastMadeAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  ingredients  RecipeIngredient[]
  tags         RecipeTag[]
  linkedFrom   RecipeLink[]       @relation("ParentRecipe")
  linkedTo     RecipeLink[]       @relation("SubRecipe")
  meals        Meal[]

  @@index([title])
  @@index([origin])
  @@index([cuisine])
  @@index([sourceUrl])
}

model RecipeIngredient {
  id       String  @id @default(cuid())
  recipeId String
  name     String
  quantity Float?
  unit     String?
  group    String?
  notes    String?
  order    Int     @default(0)

  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, order])
  @@index([name])
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String
  tag      String

  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tag])
  @@index([tag])
}

model RecipeLink {
  id          String @id @default(cuid())
  parentId    String
  subRecipeId String

  parent      Recipe @relation("ParentRecipe", fields: [parentId], references: [id], onDelete: Cascade)
  subRecipe   Recipe @relation("SubRecipe", fields: [subRecipeId], references: [id], onDelete: Restrict)

  @@unique([parentId, subRecipeId])
  @@index([subRecipeId])
}

enum ChatSessionState {
  idle
  waiting_for_input
  completing_input
  completed
  failed
}

model ChatSession {
  id                    String                @id @default(cuid())
  ownerId               String                @default("web-default")
  copilotSessionId      String?
  title                 String?
  state                 ChatSessionState      @default(idle)
  pendingInputRequestId String?
  pendingQuestion       String?
  pendingChoicesJson    String?
  pendingAllowFreeform  Boolean               @default(true)
  pendingRequestedAt    DateTime?
  pendingRetryCount     Int                   @default(0)
  pendingLastErrorCode  String?
  pendingLastRequestId  String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  messages              ChatMessage[]
  actions               ChatAction[]
  pendingSuggestions    ChatPendingSuggestion[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, state, updatedAt])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
}

model ChatAction {
  id            String      @id @default(cuid())
  chatSessionId String
  domain        String
  actionType    String
  summary       String
  forwardJson   String
  inverseJson   String
  undoneAt      DateTime?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@index([chatSessionId, undoneAt])
}

model ChatPendingSuggestion {
  id            String      @id @default(cuid())
  chatSessionId String
  domain        String
  title         String
  payloadJson   String
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@index([chatSessionId, expiresAt])
}

model CustomPersona {
  id          String   @id @default(cuid())
  emoji       String
  title       String
  description String
  prompt      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
