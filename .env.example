NEXT_PUBLIC_APP_NAME="Copilot Chef"

# Copilot model to use for AI chat. Defaults to gpt-4o-mini if not set.
# Set this in src/web/.env.local (Next.js picks it up automatically).
# Run `copilot login` to authenticate before starting the dev server.
COPILOT_MODEL=gpt-4o-mini

# Optional. Comma-separated Copilot MCP server definitions.
COPILOT_MCP_SERVERS=

# Optional. PA machine auth settings used by the web app API routes.
PA_MACHINE_AUTH_ENABLED=
PA_MACHINE_STRICT_ROUTES=
PA_MACHINE_AUTH_TOKENS=
PA_MACHINE_AUTH_TOKEN=
PA_MACHINE_CALLER_ID=
PA_MACHINE_SOURCE=

# Optional. Enables fallback-first chat routing in the web app.
COPILOT_CHAT_ROUTE_FALLBACK_FIRST=
