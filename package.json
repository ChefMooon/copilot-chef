{
  "name": "copilot-chef",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered meal-planning desktop app",
  "main": "./out/main/index.js",
  "productName": "Copilot Chef",
  "build": {
    "appId": "com.copilot-chef.app",
    "icon": "resources/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "ChefMooon",
        "repo": "copilot-chef"
      }
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*"]
      },
      {
        "from": "prisma",
        "to": "prisma",
        "filter": ["schema.prisma"]
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules/@prisma/client",
        "to": "node_modules/@prisma/client",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules/@prisma/engines",
        "to": "node_modules/@prisma/engines",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "resources/icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Copilot Chef"
    },
    "linux": {
      "icon": "resources/icon.png"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "npm run db:generate",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "npm run db:generate && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/main/server/scripts/seed.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@github/copilot-sdk": "^0.1.32",
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.68.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "defuddle": "^0.14.0",
    "domhandler": "^5.0.3",
    "electron-updater": "^6.6.2",
    "hono": "^4.7.0",
    "lucide-react": "^0.510.0",
    "parse-ingredient": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "recharts": "^2.15.3",
    "smol-toml": "^1.3.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^4.1.0"
  }
}
